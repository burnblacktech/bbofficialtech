backend/certs/*.p12
backend/certs/*.cer
backend/certs/*.pem
backend/certs/*.json
!backend/certs/.gitignore
!backend/certs/README.md

# Documentation (keep only README)
BBDocs/
*.pdf
*.md
!README.md
!backend/README.md
!backend/certs/README.md

# Scripts / temp tools
*.py

# Vercel
.vercel

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
backend/uploads/
frontend/public/uploads/

