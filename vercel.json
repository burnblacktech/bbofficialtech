{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/build",
  "installCommand": "cd backend && npm install --omit=dev && cd ../frontend && npm install",
  "framework": null,
  "functions": {
    "backend/api/index.js": {
      "maxDuration": 60,
      "includeFiles": "backend/src/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/api/index.js" },
    { "source": "/health", "destination": "/backend/api/index.js" },
    { "source": "/(.*)", "destination": "/frontend/$1" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "regions": ["bom1"],
  "env": {
    "NODE_ENV": "production",
    "CI": "false"
  }
}
