{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["backend/src/**", "backend/package.json"]
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/backend/api/index.js" },
    { "source": "/health", "destination": "/backend/api/index.js" },
    { "source": "/static/:path*", "destination": "/frontend/static/:path*" },
    { "source": "/manifest.json", "destination": "/frontend/manifest.json" },
    { "source": "/favicon.ico", "destination": "/frontend/favicon.ico" },
    { "source": "/bb-logo.svg", "destination": "/frontend/bb-logo.svg" },
    { "source": "/robots.txt", "destination": "/frontend/robots.txt" },
    { "source": "/asset-manifest.json", "destination": "/frontend/asset-manifest.json" },
    { "source": "/(.*)", "destination": "/frontend/index.html" }
  ],
  "headers": [
    {
      "source": "/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "regions": ["bom1"]
}
