# =====================================================
# BURNBACK ITR FILING PLATFORM - ENVIRONMENT VARIABLES
# =====================================================

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# =====================================================
# DATABASE — Switchable: Local Postgres OR Cloud (Neon/Supabase/Railway/RDS)
# =====================================================

# MODE 1: Cloud — Single connection string (Neon, Supabase, Railway, RDS)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# DATABASE_SSL=true  (auto-detected for Neon/Supabase URLs)

# MODE 2: Local — Individual vars
DB_HOST=localhost
DB_PORT=5432
DB_NAME=burnblack_itr
DB_USER=postgres
DB_PASSWORD=your_password_here

# Pool (auto-tuned: 3 max for serverless/Vercel, 20 for server)
# DB_POOL_MAX=20
# DB_POOL_MIN=5

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@burnblack.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,doc,docx

# Document Optimization (Quick Wins)
ENABLE_IMAGE_COMPRESSION=true
ENABLE_THUMBNAIL_GENERATION=true
MAX_IMAGE_DIMENSION=2000
IMAGE_QUALITY=85

# External API Configuration - SurePass PAN Verification
SUREPASS_API_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9..V7aJ6Z1L7xpu1CqLTHdDR6SNOT7bo3NzSL7ZQk1T-mE
SUREPASS_API_BASE_URL=https://api.surepass.io/api/v1
FEATURE_PAN_VERIFICATION_LIVE=true

# ERI (E-Return Intermediary) Configuration - Income Tax Department Integration
# UAT Credentials (from erihelp@incometax.gov.in)
ERI_USER_ID=ERIP013662
ERI_PASSWORD=Oracle@123
ERI_SECRET_KEY=FUisvaGyCVPKsYmbczcr0A==
ERI_API_URL=https://api.incometax.gov.in/eri

# PKCS12 certificate for CMS/PKCS#7 signing
# Generate with: node scripts/eri-generate-signed-payload.js
ERI_P12_CERT_PATH=./certs/eri-certificate.p12
ERI_P12_PASSWORD=your_certificate_password_here

# Client credentials (provided during ERI Type 2 registration)
ERI_CLIENT_ID=
ERI_CLIENT_SECRET=

# Mode: MOCK (dev), SANDBOX (UAT testing), LIVE (production)
ERI_MODE=MOCK

# Redis Configuration (for caching, rate limiting, sessions, pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Redis connection pool settings
REDIS_MAX_RETRIES=10
REDIS_CONNECT_TIMEOUT=10000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ITR Configuration
ITR_CURRENT_YEAR=2024-25
ITR_PREVIOUS_YEAR=2023-24
ITR_DEADLINE=2024-07-31

# Business Configuration
COMPANY_NAME=BurnBlack
COMPANY_EMAIL=support@burnblack.com
COMPANY_PHONE=+91-9876543210
COMPANY_ADDRESS=Your Company Address

# Development Configuration
DEBUG=true
VERBOSE_LOGGING=true
MOCK_EXTERNAL_APIS=true