# =====================================================
# BURNBACK ITR FILING PLATFORM - ENVIRONMENT VARIABLES
# =====================================================

# Server Configuration
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# =====================================================
# DATABASE — Switchable: Local Postgres OR Cloud (Neon/Supabase/Railway/RDS)
# =====================================================

# MODE 1: Cloud — Single connection string (Neon, Supabase, Railway, RDS)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
# DATABASE_SSL=true  (auto-detected for Neon/Supabase URLs)

# MODE 2: Local — Individual vars
DB_HOST=localhost
DB_PORT=5432
DB_NAME=burnblack_itr
DB_USER=postgres
DB_PASSWORD=your_password_here

# Pool (auto-tuned: 3 max for serverless/Vercel, 20 for server)
# DB_POOL_MAX=20
# DB_POOL_MIN=5

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3002/api/auth/google/callback

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@burnblack.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=pdf,jpg,jpeg,png,doc,docx

# Document Optimization (Quick Wins)
ENABLE_IMAGE_COMPRESSION=true
ENABLE_THUMBNAIL_GENERATION=true
MAX_IMAGE_DIMENSION=2000
IMAGE_QUALITY=85

# External API Configuration - SurePass PAN Verification
SUREPASS_API_KEY=your_surepass_api_key_here
SUREPASS_API_BASE_URL=https://api.surepass.io/api/v1
FEATURE_PAN_VERIFICATION_LIVE=true

# SurePass ITR Fetch (26AS/AIS via ITD portal)
FEATURE_ITR_FETCH_LIVE=false

# ERI (E-Return Intermediary) Configuration - Income Tax Department Integration
ERI_USER_ID=your_eri_user_id_here
ERI_PASSWORD=your_eri_password_here
ERI_SECRET_KEY=your_eri_secret_key_here
ERI_API_URL=https://api.incometax.gov.in/eri

# PKCS12 certificate for CMS/PKCS#7 signing
ERI_P12_CERT_PATH=./certs/eri-certificate.p12
ERI_P12_PASSWORD=your_certificate_password_here

# Client credentials (provided during ERI Type 2 registration)
ERI_CLIENT_ID=your_eri_client_id_here
ERI_CLIENT_SECRET=your_eri_client_secret_here

# Mode: MOCK (dev), SANDBOX (UAT testing), LIVE (production)
ERI_MODE=MOCK

# Redis Configuration (for caching, rate limiting, sessions, pub/sub)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=10
REDIS_CONNECT_TIMEOUT=10000

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Security Configuration
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
SESSION_SECRET=your_session_secret_here
COOKIE_DOMAIN=localhost
MAX_CONCURRENT_SESSIONS=5

# Field-level encryption
FIELD_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here
FIELD_HMAC_KEY=your_hmac_key_here

# ITR Configuration
ITR_CURRENT_YEAR=2024-25
ITR_PREVIOUS_YEAR=2023-24
ITR_DEADLINE=2024-07-31

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
R2_ENDPOINT=your_r2_endpoint_here
R2_BUCKET=your_r2_bucket_name_here

# Monitoring
SENTRY_DSN=your_sentry_dsn_here

# CORS / Domain
ALLOWED_VERCEL_DOMAIN=your_vercel_domain_here

# Business Configuration
COMPANY_NAME=BurnBlack
COMPANY_EMAIL=support@burnblack.com
COMPANY_PHONE=+91-9876543210
COMPANY_ADDRESS=Your Company Address

# Development Configuration
DEBUG=true
VERBOSE_LOGGING=true
MOCK_EXTERNAL_APIS=true
